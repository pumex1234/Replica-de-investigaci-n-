\newlabel{fig:msa_sources}{{9}{5}{Mejor \gdtts {} obtenido para T1266-D1 estratificado por fuente MSA. La variación de rendimiento entre fuentes demuestra que la captura de señal evolutiva depende de la fuente, justificando la estrategia multi-MSA}{figure.caption.10}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.3.2}Efecto Cuantitativo del Particionamiento de Dominios}{5}{subsubsection.3.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Efecto de la ingeniería de dominios en T1266-D1: la predicción estándar de cadena completa alcanza \textsc  {GDT-TS}{} = 87,88, mientras que el particionamiento consciente de dominios eleva el rendimiento a \textsc  {GDT-TS}{} = 88,56 ($\Delta $ = +0,68 puntos), confirmando el hallazgo original.}}{5}{figure.caption.11}\protected@file@percent }
\newlabel{fig:domain_effect}{{10}{5}{Efecto de la ingeniería de dominios en T1266-D1: la predicción estándar de cadena completa alcanza \gdtts {} = 87,88, mientras que el particionamiento consciente de dominios eleva el rendimiento a \gdtts {} = 88,56 ($\Delta $ = +0,68 puntos), confirmando el hallazgo original}{figure.caption.11}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Análisis de Métodos de Evaluación de Calidad}{5}{subsection.3.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.1}Concordancia de Rankings Entre Métodos}{5}{subsubsection.3.4.1}\protected@file@percent }
\def\@LN@column{2}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Rankings de los 20 mejores modelos para T1226-D1 por pLDDT (izquierda) y puntuación GATE (derecha). La codificación por colores indica la familia del motor de predicción: rojo = AlphaFold3{}, azul = DeepMSA, verde = ColabFold, gris = AF2 estándar. Notablemente, los modelos de AlphaFold3{} tienen pLDDT bajo pero altas puntuaciones por pares, mientras que DeepMSA domina el ranking de pLDDT.}}{5}{figure.caption.12}\protected@file@percent }
\newlabel{fig:qa_rankings}{{11}{5}{Rankings de los 20 mejores modelos para T1226-D1 por pLDDT (izquierda) y puntuación GATE (derecha). La codificación por colores indica la familia del motor de predicción: rojo = \afthree {}, azul = DeepMSA, verde = ColabFold, gris = AF2 estándar. Notablemente, los modelos de \afthree {} tienen pLDDT bajo pero altas puntuaciones por pares, mientras que DeepMSA domina el ranking de pLDDT}{figure.caption.12}{}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {3.4.2}Divergencia de Métodos QA en la Selección del Top-1}{5}{subsubsection.3.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Puntuación del modelo Top-1 seleccionado por cada método QA para T1226-D1. La divergencia entre métodos (pLDDT, GATE, pairwise, EnQA, GCPNet-EMA) confirma que ninguna métrica individual es universalmente óptima, validando el enfoque integrativo de \textsc  {Multicom4}{}.}}{5}{figure.caption.13}\protected@file@percent }
\newlabel{fig:qa_methods}{{12}{5}{Puntuación del modelo Top-1 seleccionado por cada método QA para T1226-D1. La divergencia entre métodos (pLDDT, GATE, pairwise, EnQA, GCPNet-EMA) confirma que ninguna métrica individual es universalmente óptima, validando el enfoque integrativo de \multicom {}}{figure.caption.13}{}}
